############################################################################################
# ATClient drop in config for a SIMCom SIM8262E-M2 5G HAT on Raspberry Pi 5
############################################################################################
# This is a ready to use SIMCom variant of atclient.cfg.sample. Copy to
# /home/mid/atclient/atclient.cfg and adjust per device. Validated on Debian 13 trixie,
# kernel 6.12.47, SIMCom firmware 22131B05X62M44A-M2.
#
# See atclient.cfg.sample for the full option list and inline documentation. This file
# only lists the values that differ from the generic sample.

modem.type = simcom

# Stable udev symlink for the AT port (see 99-sim8262.rules). Do not hard code
# /dev/ttyUSB2; USB re enumeration after AT+CFUN=1,1 can renumber devices.
port.name.linux   = SimTech
port.name.windows = SimTech
port.baudrate     = 115200
port.databits     = 8
port.stopbits     = 1
port.parity       = 0
port.communication.timeout = 5000

atclient.atcommand.heartbeat = 180000

# Default to LTE plus NR5G. Switch to nr_only for a device dedicated to 5G SA monitoring.
simcom.network.mode = lte_nr5g

# Left blank on SIMCom. cops.mode is PLS8 only and ignored by the SIMCom driver.
cops.mode =

# 5G SA auto recovery. Only takes effect when simcom.network.mode = nr_only.
simcom.sa.recovery.enabled                = true
simcom.sa.recovery.tier1.misses           = 1
simcom.sa.recovery.tier2.misses           = 2
simcom.sa.recovery.tier3.misses           = 3
simcom.sa.recovery.cooldown.tier1.seconds = 180
simcom.sa.recovery.cooldown.tier2.seconds = 600
simcom.sa.recovery.cooldown.tier3.seconds = 1800

simcom.stk.format = decoded
simcom.data.apn   = gprs.swisscom.ch

# Watchdog events match the +STIN codes that Mobile ID emits on SIMCom:
# 21 DISPLAY TEXT, 23 GET INPUT, 25 SET UP MENU (post session return to idle marker).
# +STIN:13 (SEND MESSAGE) is not emitted by the Mobile ID applet on SIMCom.
watchdog.enable                 = true
watchdog.file                   = /var/log/watchdog.atclient
watchdog.mode                   = activity
watchdog.activity.events        = 21,23,25
watchdog.activity.startup.grace = 300000

# Maintenance script is not used on SIMCom; modem-data.service and autossh.service
# own the data path and reverse tunnel.
maintenance.enable      = false
maintenance.script.file = /home/mid/atclient/maintenance.sh
